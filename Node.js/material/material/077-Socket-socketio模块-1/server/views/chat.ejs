        var send =document.querySelector("#send")
        var text =document.querySelector("#text")
        var user =document.querySelector("#user")
        user.innerHTML = localStorage.getItem("username")

        const WebSocketType = {
            Error:0, //错误
            GroupList:1,//获取列表
            GroupChat:2, //群聊
            SingleChat:3 //私聊
        }
        //引入io js端（客服端--->）  放到了public de javascript的socketio.js里面
        const socket = io(`ws://localhost:3000?token=${localStorage.getItem("token")}`)  //传空默认连接端口3000
        socket.on("xian",(msg)=>{
            console.log(msg)
        })

        socket.on(WebSocketType.GroupChat,(msg)=>{
            // console.log(msg.user)
            var title = msg.user ? msg.user.username : "广播"
            console.log(title + " : " + msg.data)
        })
        socket.on(WebSocketType.Error,(msg)=>{
            localStorage.removeItem("token")
            location.href = "/login"
        })
        


